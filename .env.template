LLM_PROVIDER=openai

# Single key used by the active provider (falls back to OPENAI_API_KEY or GEMINI_API_KEY if unset)
LLM_API_KEY=

# Model id (e.g. gpt-4o-mini, gemini-2.0-flash)
LLM_MODEL=gpt-4o-mini

# OpenAI-compatible base URL (LM Studio, Azure-style gateways, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional overrides
# DATABASE_PATH=dental.db
# FAQ_PATH=path/to/custom_faq.json
