# LLM Provider (openai, gemini)
LLM_PROVIDER=openai

# LLM API Key
LLM_API_KEY=

# LLM Model (e.g. gpt-4o-mini, gemini-2.0-flash)
LLM_MODEL=gpt-4o-mini

# Display timezone for "today", business hours, and agent-facing times (IANA name)
DISPLAY_TIMEZONE=America/Los_Angeles

# Database Path
DATABASE_PATH=dental.db

# FAQ Path
FAQ_PATH=path/to/custom_faq.json
